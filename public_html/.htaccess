# Personal Recipe Book — front-controller routing for shared cPanel hosts.
# Apache 2.4+. Falls through to a small index.php router.

Options -Indexes
DirectoryIndex index.php

<IfModule mod_rewrite.c>
  RewriteEngine On

  # If the request maps to a real file or directory (CSS, JS, images, install.php),
  # serve it directly. Everything else goes to the front controller.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ index.php [QSA,L]
</IfModule>

# Block dotfiles and the generated config from being served directly.
<FilesMatch "^\.">
  Require all denied
</FilesMatch>
<Files "config.php">
  Require all denied
</Files>
<Files "config.example.php">
  Require all denied
</Files>

# Reasonable defaults for static assets.
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "same-origin"
</IfModule>
